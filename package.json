    "class-variance-authority": "0.7.0",
    "clsx": "2.1.1",
    "dotenv": "16.4.5",
    "ioredis": "5.4.1",
    "lucide-react": "0.451.0",
    "next": "14.2.35",
    "next-auth": "5.0.0-beta.22",
    "p-limit": "^7.3.0",
    "pino": "9.4.0",
    "pino-pretty": "11.2.2",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "sharp": "0.33.5",
    "tailwind-merge": "2.5.3",
