{
  "name": "etsyhub",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "worker": "tsx watch scripts/dev-worker.ts",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "check:tokens": "tsx scripts/check-tokens.ts",
    "test": "vitest run",
    "test:ui": "vitest run --config vitest.config.ui.ts",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:all": "npm run typecheck && npm run lint && npm run check:tokens && npm run test && npm run test:ui && npm run test:e2e",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "db:reset": "tsx scripts/reset-db.ts",
    "cleanup:test-mockup-templates": "tsx scripts/cleanup-test-mockup-templates.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.670.0",
    "@aws-sdk/s3-request-presigner": "3.670.0",
    "@imgly/background-removal-node": "^1.4.5",
    "@paralleldrive/cuid2": "2.2.2",
    "@prisma/client": "5.20.0",
    "@radix-ui/react-dialog": "1.1.2",
    "@radix-ui/react-dropdown-menu": "2.1.2",
    "@radix-ui/react-slot": "1.1.0",
    "@radix-ui/react-tabs": "1.1.1",
    "@radix-ui/react-toast": "1.2.2",
    "@tanstack/react-query": "5.59.0",
    "apify-client": "^2.23.0",
    "archiver": "^7.0.1",
    "bcryptjs": "2.4.3",
    "bullmq": "5.20.0",
