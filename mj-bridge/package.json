{
  "name": "mj-bridge",
  "version": "0.1.0",
  "private": true,
  "description": "EtsyHub Midjourney Web Bridge — local Node.js service that runs visible Chromium against midjourney.com",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "fastify": "^4.27.0",
    "playwright": "^1.45.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vitest": "^2.1.2"
  },
  "engines": {
    "node": ">=20"
  }
}
