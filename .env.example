# App
NODE_ENV=development
APP_URL=http://localhost:3000
LOG_LEVEL=debug

# Auth
AUTH_SECRET=replace-with-openssl-rand-32-chars-minimum
AUTH_TRUST_HOST=true
# Register: lokal geliştirmede true; production/final default: false (admin daveti ile kayıt)
REGISTRATION_ENABLED=true
ADMIN_EMAIL=admin@etsyhub.local
ADMIN_PASSWORD=change-me-admin12345

# Secrets encryption (32-byte hex key — üretim için: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
SECRETS_ENCRYPTION_KEY=replace-with-64-hex-chars

# Database
DATABASE_URL=postgresql://etsyhub:etsyhub_dev@localhost:5432/etsyhub?schema=public
DATABASE_URL_TEST=postgresql://etsyhub:etsyhub_dev@localhost:5432/etsyhub_test?schema=public

# Redis / Queue
REDIS_URL=redis://localhost:6379

# Storage (MinIO varsayılan)
STORAGE_PROVIDER=minio
STORAGE_BUCKET=etsyhub
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_REGION=us-east-1
STORAGE_ACCESS_KEY=etsyhub
STORAGE_SECRET_KEY=etsyhub_dev_secret
STORAGE_FORCE_PATH_STYLE=true
STORAGE_PUBLIC_URL=http://localhost:9000

# Etsy OAuth — Phase 9 foundation. V1: env yoksa submit endpoint 503 honest fail.
# Production: developer.etsy.com'dan oluşturulan App credentials.
# ETSY_CLIENT_ID=
# ETSY_CLIENT_SECRET=
# ETSY_REDIRECT_URI=http://localhost:3000/api/etsy/oauth/callback
