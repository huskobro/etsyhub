generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============= ENUMS =============

enum UserRole {
  USER
  ADMIN
}

enum UserStatus {
  ACTIVE
  DISABLED
}

enum BookmarkStatus {
  INBOX
  REFERENCED
  ARCHIVED
  RISKY
}

enum RiskLevel {
  NONE
  LOW
  MEDIUM
  HIGH
}

enum SourcePlatform {
  ETSY
  AMAZON
  PINTEREST
  INSTAGRAM
  UPLOAD
  OTHER
}

enum CollectionKind {
  BOOKMARK
  REFERENCE
  MIXED
}

enum JobStatus {
  QUEUED
  RUNNING
  SUCCESS
  FAILED
  CANCELLED
}

enum JobType {
  ASSET_INGEST_FROM_URL
  GENERATE_THUMBNAIL
  BOOKMARK_PREVIEW_METADATA
  SCRAPE_COMPETITOR
  FETCH_NEW_LISTINGS
  GENERATE_VARIATIONS
  REVIEW_DESIGN
  REMOVE_BACKGROUND
  UPSCALE_IMAGE
  CREATE_MOCKUP
  GENERATE_LISTING_COPY
  PUSH_ETSY_DRAFT
  EXPORT_CLIPART_BUNDLE
  SIMILARITY_CHECK
  TREND_CLUSTER_UPDATE
  SCAN_LOCAL_FOLDER
  EXPORT_SELECTION_SET
  SELECTION_EXPORT_CLEANUP
}

enum VariationState {
  QUEUED
  PROVIDER_PENDING
  PROVIDER_RUNNING
  SUCCESS
  FAIL
}

enum VariationCapability {
  IMAGE_TO_IMAGE
  TEXT_TO_IMAGE
}

enum ReviewStatus {
  PENDING
  APPROVED
  NEEDS_REVIEW
  REJECTED
}

enum ReviewStatusSource {
  SYSTEM
  USER
}

enum ListingStatus {
  DRAFT
  SCHEDULED
  PUBLISHED
  FAILED
  REJECTED
  NEEDS_REVIEW
}

enum ThemeStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum PromptStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum FeatureFlagScope {
  GLOBAL
  USER
  STORE
}

enum ProviderKind {
  AI
  SCRAPER
  MOCKUP
  STORAGE
  ETSY
  OCR
}

enum TrendClusterStatus {
  ACTIVE
  STALE
  ARCHIVED
}

// ============= CORE =============

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  passwordHash String
  name         String?
  role         UserRole   @default(USER)
  status       UserStatus @default(ACTIVE)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  deletedAt    DateTime?

  stores             Store[]
  bookmarks          Bookmark[]
  references         Reference[]
  collections        Collection[]
  tags               Tag[]
  assets             Asset[]
  jobs               Job[]
  auditLogs          AuditLog[]
  generatedDesigns   GeneratedDesign[]
  mockups            Mockup[]
  listings           Listing[]
  competitorStores   CompetitorStore[]
  competitorListings CompetitorListing[]
  competitorScans    CompetitorScan[]
  costUsages         CostUsage[]
  trendClusters      TrendCluster[]
  localLibraryAssets LocalLibraryAsset[]
  settings           UserSetting[]
  selectionSets      SelectionSet[]
  mockupJobs         MockupJob[]

  @@index([deletedAt])
}

model Store {
  id             String    @id @default(cuid())
  userId         String
  user           User      @relation(fields: [userId], references: [id], onDelete: Restrict)
  name           String
  niche          String?
  targetAudience String?
  tone           String?
  preferredStyle String?
  bannedTerms    String[]  @default([])
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  etsyConnection   EtsyConnection?
  bookmarks        Bookmark[]
  references       Reference[]
  competitorStores CompetitorStore[]
  listings         Listing[]
  jobs             Job[]

  @@index([userId])
}

model EtsyConnection {
  id           String    @id @default(cuid())
  storeId      String    @unique
  store        Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  shopId       String?
  shopName     String?
  accessToken  String?
  refreshToken String?
  tokenExpires DateTime?
  scopes       String[]  @default([])
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model CompetitorStore {
  id              String         @id @default(cuid())
  userId          String
  user            User           @relation(fields: [userId], references: [id], onDelete: Restrict)
  storeId         String?
  store           Store?         @relation(fields: [storeId], references: [id])
  etsyShopName    String // canonical: lowercase, trimmed (service enforces)
  shopUrl         String? // canonical: normalized (service enforces)
  platform        SourcePlatform @default(ETSY)
  displayName     String? // scraper'dan dönen gerçek mağaza adı
  totalListings   Int? // son scan snapshot
  totalReviews    Int? // son scan snapshot
  autoScanEnabled Boolean        @default(false) // FETCH_NEW_LISTINGS için opt-in
  lastScannedAt   DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  deletedAt       DateTime?

  listings CompetitorListing[]
  scans    CompetitorScan[]

  @@unique([userId, etsyShopName])
  @@index([storeId])
  @@index([userId])
}

enum CompetitorListingStatus {
  ACTIVE
  SOLD_OUT
  DELETED
  UNKNOWN
}

model CompetitorListing {
  id                String                  @id @default(cuid())
  competitorStoreId String
  competitorStore   CompetitorStore         @relation(fields: [competitorStoreId], references: [id], onDelete: Cascade)
  userId            String // denormalize — data isolation filter için
  user              User                    @relation(fields: [userId], references: [id], onDelete: Restrict)
  externalId        String // Etsy listing_id veya Amazon ASIN; canonical normalized (service responsibility)
  platform          SourcePlatform
  sourceUrl         String // canonical normalized URL (service responsibility)
  title             String
  thumbnailUrl      String?
  imageUrls         String[]                @default([])
  priceCents        Int?
  currency          String?
  reviewCount       Int                     @default(0)
  favoritesCount    Int? // Etsy "favori" sayısı
  // --- Tarih alanları (üç farklı zaman) ---
  listingCreatedAt  DateTime? // scraper'dan gelen listing oluşturma / publish tarihi (varsa)
  latestReviewAt    DateTime? // son review tarihi (ranking'de "son 30 gün" için)
  firstSeenAt       DateTime                @default(now()) // bizim DB'ye ilk düştüğü an
  lastSeenAt        DateTime                @default(now()) // bizim son scan'de gördüğümüz an
  // --- Parser debug ---
  parserSource      String? // hangi parser path: "json-ld", "og-meta", "fallback"
  parserConfidence  Int? // 0-100, parse kalitesi
  parseWarnings     String[]                @default([]) // partial parse uyarıları
  // --- Durum + raw ---
  status            CompetitorListingStatus @default(ACTIVE)
  rawMetadata       Json? // scraper'dan ham veri (debug + ileride yeni alan ekleme için)
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt

  trendMembers   TrendClusterMember[]
  heroOfClusters TrendCluster[]       @relation("TrendClusterHero")

  @@unique([competitorStoreId, externalId])
  @@index([userId])
  @@index([competitorStoreId, reviewCount(sort: Desc)])
  @@index([competitorStoreId, lastSeenAt(sort: Desc)])
  @@index([competitorStoreId, latestReviewAt(sort: Desc)])
}

enum CompetitorScanType {
  INITIAL_FULL
  INCREMENTAL_NEW
  MANUAL_REFRESH
}

enum CompetitorScanStatus {
  QUEUED
  RUNNING
  SUCCESS
  FAILED
  PARTIAL
}

model CompetitorScan {
  id                String               @id @default(cuid())
  competitorStoreId String
  competitorStore   CompetitorStore      @relation(fields: [competitorStoreId], references: [id], onDelete: Cascade)
  userId            String
  user              User                 @relation(fields: [userId], references: [id], onDelete: Restrict)
  jobId             String? // Job tablosu bağlantısı (BullMQ + internal Job row)
  type              CompetitorScanType
  status            CompetitorScanStatus @default(QUEUED)
  provider          String // "apify" | "firecrawl" | "self-hosted"
  listingsFound     Int                  @default(0)
  listingsNew       Int                  @default(0)
  listingsUpdated   Int                  @default(0)
  listingsRemoved   Int                  @default(0)
  parseWarnings     String[]             @default([]) // scan bazında toplanmış parser uyarıları
  errorMessage      String?
  /// Workflow metadata. Bilinen key'ler: trendEnqueueError (scrape SUCCESS sonrası trend cluster enqueue başarısız olursa hata mesajı).
  metadata          Json?
  startedAt         DateTime?
  finishedAt        DateTime?
  createdAt         DateTime             @default(now())

  @@index([competitorStoreId, createdAt(sort: Desc)])
  @@index([userId])
}

model Asset {
  id              String          @id @default(cuid())
  userId          String
  user            User            @relation(fields: [userId], references: [id], onDelete: Restrict)
  storageProvider String
  storageKey      String
  bucket          String
  mimeType        String
  sizeBytes       Int
  width           Int?
  height          Int?
  hash            String
  sourceUrl       String?
  sourcePlatform  SourcePlatform?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  deletedAt       DateTime?

  bookmarks        Bookmark[]
  references       Reference[]
  generatedDesigns GeneratedDesign[]
  mockups          Mockup[]

  selectionItemsAsSource   SelectionItem[] @relation("SelectionItemSourceAsset")
  selectionItemsAsEdited   SelectionItem[] @relation("SelectionItemEditedAsset")
  selectionItemsAsUndoable SelectionItem[] @relation("SelectionItemUndoableAsset")

  @@index([userId])
  @@index([hash])
}

model Collection {
  id          String         @id @default(cuid())
  userId      String
  user        User           @relation(fields: [userId], references: [id], onDelete: Restrict)
  name        String
  slug        String
  description String?
  kind        CollectionKind @default(MIXED)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  deletedAt   DateTime?

  bookmarks  Bookmark[]
  references Reference[]

  @@unique([userId, slug])
  @@index([userId])
}

model Tag {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Restrict)
  name      String
  // color: semantic/token key (ör. "accent", "success", "warning", "berry"). Raw hex yasak.
  color     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bookmarkTags  BookmarkTag[]
  referenceTags ReferenceTag[]

  @@unique([userId, name])
  @@index([userId])
}

model ProductType {
  id          String   @id @default(cuid())
  key         String   @unique
  displayName String
  aspectRatio String?
  description String?
  isSystem    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  bookmarks        Bookmark[]
  references       Reference[]
  generatedDesigns GeneratedDesign[]
  listings         Listing[]
  recipes          Recipe[]
  trendClusters    TrendCluster[]
}

model Bookmark {
  id             String         @id @default(cuid())
  userId         String
  user           User           @relation(fields: [userId], references: [id], onDelete: Restrict)
  storeId        String?
  store          Store?         @relation(fields: [storeId], references: [id])
  assetId        String?
  asset          Asset?         @relation(fields: [assetId], references: [id])
  sourceUrl      String?
  sourcePlatform SourcePlatform @default(OTHER)
  title          String?
  notes          String?
  status         BookmarkStatus @default(INBOX)
  riskLevel      RiskLevel      @default(NONE)
  productTypeId  String?
  productType    ProductType?   @relation(fields: [productTypeId], references: [id])
  collectionId   String?
  collection     Collection?    @relation(fields: [collectionId], references: [id])
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  deletedAt      DateTime?

  trendClusterId            String?
  trendCluster              TrendCluster? @relation(fields: [trendClusterId], references: [id], onDelete: SetNull)
  trendClusterLabelSnapshot String?
  trendWindowDaysSnapshot   Int?

  tags       BookmarkTag[]
  references Reference[]

  @@index([userId])
  @@index([status])
  @@index([productTypeId])
  @@index([collectionId])
  @@index([trendClusterId])
}

model BookmarkTag {
  bookmarkId String
  tagId      String
  bookmark   Bookmark @relation(fields: [bookmarkId], references: [id], onDelete: Cascade)
  tag        Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([bookmarkId, tagId])
}

model Reference {
  id            String      @id @default(cuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Restrict)
  storeId       String?
  store         Store?      @relation(fields: [storeId], references: [id])
  bookmarkId    String?
  bookmark      Bookmark?   @relation(fields: [bookmarkId], references: [id])
  assetId       String
  asset         Asset       @relation(fields: [assetId], references: [id], onDelete: Restrict)
  productTypeId String
  productType   ProductType @relation(fields: [productTypeId], references: [id])
  collectionId  String?
  collection    Collection? @relation(fields: [collectionId], references: [id])
  notes         String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  deletedAt     DateTime?

  tags             ReferenceTag[]
  generatedDesigns GeneratedDesign[]

  @@index([userId])
  @@index([productTypeId])
  @@index([collectionId])
}

model ReferenceTag {
  referenceId String
  tagId       String
  reference   Reference @relation(fields: [referenceId], references: [id], onDelete: Cascade)
  tag         Tag       @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([referenceId, tagId])
}

// ============= PROMPTS / RECIPES =============

model PromptTemplate {
  id             String       @id @default(cuid())
  name           String       @unique
  taskType       String
  productTypeKey String?
  providerKind   ProviderKind
  providerKey    String?
  model          String?
  description    String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  versions PromptVersion[]
}

model PromptVersion {
  id                 String         @id @default(cuid())
  templateId         String
  template           PromptTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  version            Int
  systemPrompt       String
  userPromptTemplate String
  outputSchema       Json?
  status             PromptStatus   @default(DRAFT)
  changelog          String?
  testInput          Json?
  testOutput         Json?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  generatedDesigns GeneratedDesign[]

  @@unique([templateId, version])
}

model Recipe {
  id            String       @id @default(cuid())
  key           String       @unique
  name          String
  productTypeId String?
  productType   ProductType? @relation(fields: [productTypeId], references: [id])
  config        Json
  isSystem      Boolean      @default(true)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

// ============= DESIGN / REVIEW / MOCKUP / LISTING =============

model GeneratedDesign {
  id                String         @id @default(cuid())
  userId            String
  user              User           @relation(fields: [userId], references: [id], onDelete: Restrict)
  referenceId       String
  reference         Reference      @relation(fields: [referenceId], references: [id], onDelete: Restrict)
  assetId           String
  asset             Asset          @relation(fields: [assetId], references: [id])
  productTypeId     String
  productType       ProductType    @relation(fields: [productTypeId], references: [id])
  promptVersionId   String?
  promptVersion     PromptVersion? @relation(fields: [promptVersionId], references: [id])
  jobId             String?
  job               Job?           @relation(fields: [jobId], references: [id])
  similarity        String?
  qualityScore      Int?
  reviewStatus      ReviewStatus   @default(PENDING)
  reviewIssues      Json?
  reviewSummary     String?
  textDetected      Boolean        @default(false)
  gibberishDetected Boolean        @default(false)
  // @deprecated Phase 6'da reviewRiskFlags (Json) kullanılır.
  // Legacy rowlar için tutuldu; migration'da silinmiyor. Yeni kod bu alanı yazmıyor.
  riskFlags         String[]       @default([])
  reviewedAt        DateTime?

  // Phase 6 — Review pipeline (additive)
  reviewStatusSource     ReviewStatusSource @default(SYSTEM)
  reviewScore            Int?
  reviewProviderSnapshot String?
  reviewPromptSnapshot   String?            @db.Text
  reviewRiskFlags        Json?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // Phase 5 — Variation Generation
  providerId     String?
  providerTaskId String?
  capabilityUsed VariationCapability?
  promptSnapshot String?              @db.Text
  briefSnapshot  String?              @db.Text
  resultUrl      String?
  state          VariationState?
  errorMessage   String?              @db.Text
  // R17.4 — kullanıcı seçimi snapshot olarak persist edilir.
  // Phase 5 öncesi rows için NULL; retry path'inde NULL gelirse 500 fail-fast
  // (sessiz default fallback YASAK). Yeni create'lerde her zaman set edilir.
  aspectRatio    String?
  // "medium" | "high"; provider opsiyonel field — null ise undefined geçer.
  quality        String?

  review         DesignReview?
  mockups        Mockup[]
  listings       Listing[]
  selectionItems SelectionItem[]

  @@index([userId])
  @@index([referenceId])
  // Phase 6 Task 14 — review queue endpoint için (userId, reviewStatus) full-scan'i önler.
  @@index([userId, reviewStatus])
}

model DesignReview {
  id                String          @id @default(cuid())
  generatedDesignId String          @unique
  generatedDesign   GeneratedDesign @relation(fields: [generatedDesignId], references: [id], onDelete: Cascade)
  reviewer          String
  score             Int?
  issues            Json?
  decision          ReviewStatus
  createdAt         DateTime        @default(now())

  // Phase 6 — Audit
  provider         String?
  model            String?
  promptSnapshot   String? @db.Text
  responseSnapshot Json?
}

model Mockup {
  id                String           @id @default(cuid())
  userId            String
  user              User             @relation(fields: [userId], references: [id], onDelete: Restrict)
  generatedDesignId String?
  generatedDesign   GeneratedDesign? @relation(fields: [generatedDesignId], references: [id])
  assetId           String
  asset             Asset            @relation(fields: [assetId], references: [id])
  templateKey       String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  deletedAt         DateTime?

  listings Listing[]

  @@index([userId])
}

model Listing {
  id                String           @id @default(cuid())
  userId            String
  user              User             @relation(fields: [userId], references: [id], onDelete: Restrict)
  storeId           String?
  store             Store?           @relation(fields: [storeId], references: [id])
  generatedDesignId String?
  generatedDesign   GeneratedDesign? @relation(fields: [generatedDesignId], references: [id])
  productTypeId     String?
  productType       ProductType?     @relation(fields: [productTypeId], references: [id])
  title             String?
  description       String?
  tags              String[]         @default([])
  category          String?
  priceCents        Int?
  materials         String[]         @default([])
  status            ListingStatus    @default(DRAFT)
  etsyDraftId       String?
  mockups           Mockup[]
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  deletedAt         DateTime?

  @@index([userId])
  @@index([status])
}

// ============= JOBS / AUDIT / FLAGS / THEME / COST =============

model Job {
  id           String    @id @default(cuid())
  userId       String?
  user         User?     @relation(fields: [userId], references: [id])
  storeId      String?
  store        Store?    @relation(fields: [storeId], references: [id])
  type         JobType
  status       JobStatus @default(QUEUED)
  progress     Int       @default(0)
  error        String?
  retryCount   Int       @default(0)
  costEstimate Int?
  bullJobId    String?   @unique
  metadata     Json?
  startedAt    DateTime?
  finishedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  generatedDesigns GeneratedDesign[]

  @@index([userId])
  @@index([status])
  @@index([type])
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id])
  actor      String
  action     String
  targetType String?
  targetId   String?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

model Theme {
  id        String      @id @default(cuid())
  name      String      @unique
  tokens    Json
  status    ThemeStatus @default(DRAFT)
  isSystem  Boolean     @default(false)
  createdBy String?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
}

model FeatureFlag {
  id        String           @id @default(cuid())
  key       String           @unique
  enabled   Boolean          @default(false)
  scope     FeatureFlagScope @default(GLOBAL)
  metadata  Json?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
}

model CostUsage {
  id           String       @id @default(cuid())
  userId       String
  user         User         @relation(fields: [userId], references: [id], onDelete: Restrict)
  providerKind ProviderKind
  providerKey  String
  model        String?
  jobId        String?
  units        Int
  costCents    Int
  periodKey    String
  createdAt    DateTime     @default(now())

  @@index([userId, periodKey])
}

model NegativeLibraryEntry {
  id        String   @id @default(cuid())
  term      String   @unique
  category  String?
  isSystem  Boolean  @default(false)
  createdAt DateTime @default(now())
}

// ============= TREND CLUSTERS =============

model TrendCluster {
  id                    String             @id @default(cuid())
  userId                String
  user                  User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  signature             String
  label                 String
  productTypeId         String?
  productType           ProductType?       @relation(fields: [productTypeId], references: [id], onDelete: SetNull)
  productTypeSource     String?
  productTypeConfidence Int?
  windowDays            Int
  memberCount           Int                @default(0)
  storeCount            Int                @default(0)
  totalReviewCount      Int                @default(0)
  latestMemberSeenAt    DateTime?
  heroListingId         String?
  heroListing           CompetitorListing? @relation("TrendClusterHero", fields: [heroListingId], references: [id], onDelete: SetNull)
  seasonalTag           String?
  status                TrendClusterStatus @default(ACTIVE)
  clusterScore          Int                @default(0)
  computedAt            DateTime           @default(now())
  updatedAt             DateTime           @updatedAt

  members   TrendClusterMember[]
  bookmarks Bookmark[]

  @@unique([userId, signature, windowDays])
  @@index([userId, status, latestMemberSeenAt(sort: Desc)])
  @@index([userId, windowDays, clusterScore(sort: Desc)])
}

model TrendClusterMember {
  id        String            @id @default(cuid())
  clusterId String
  cluster   TrendCluster      @relation(fields: [clusterId], references: [id], onDelete: Cascade)
  listingId String
  listing   CompetitorListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  userId    String
  addedAt   DateTime          @default(now())

  @@unique([clusterId, listingId])
  @@index([listingId])
  @@index([userId, clusterId])
  @@index([userId, listingId])
}

// ============= LOCAL LIBRARY (Phase 5) =============

model LocalLibraryAsset {
  id             String  @id @default(cuid())
  userId         String
  folderName     String
  folderPath     String
  fileName       String
  filePath       String
  hash           String
  mimeType       String
  fileSize       Int
  width          Int
  height         Int
  dpi            Int?
  thumbnailPath  String?
  qualityScore   Int?
  qualityReasons Json?

  // Phase 6 — Review pipeline
  reviewStatus           ReviewStatus       @default(PENDING)
  reviewStatusSource     ReviewStatusSource @default(SYSTEM)
  reviewScore            Int?
  reviewSummary          String?            @db.Text
  reviewIssues           Json?
  reviewRiskFlags        Json?
  reviewedAt             DateTime?
  reviewProviderSnapshot String?
  reviewPromptSnapshot   String?            @db.Text

  isNegative     Boolean   @default(false)
  negativeReason String?
  // R7 dual-flag soft-delete:
  //   isUserDeleted = true  -> kullanıcı UI'dan açık "sil" dedi (manuel)
  //   deletedAt     != null -> kayıt artık aktif değil; auto-silme (örn. scan
  //                            worker dosyayı diskte bulamadığında) veya user
  //                            silmesinin timestamp'i. Aktif listing query'leri
  //                            iki koşulu da kontrol etmeli.
  isUserDeleted  Boolean   @default(false)
  deletedAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@unique([userId, hash])
  @@index([userId, folderName])
  @@index([userId, isNegative])
  @@index([userId, isUserDeleted, deletedAt])
  // Phase 6 Task 14 — review queue endpoint için (userId, reviewStatus) full-scan'i önler.
  @@index([userId, reviewStatus])
}

// ============= USER SETTINGS (Phase 5 §8) =============
//
// Generic key/value store: tek kullanıcı için birden fazla setting grubu.
// Bilinen key'ler (camelCase, parçalı saçılma YASAK):
//   - "localLibrary": { rootFolderPath, targetResolution, targetDpi }
//   - "aiMode": { kieApiKey (cipher), geminiApiKey (cipher) }

model UserSetting {
  userId String
  key    String
  value  Json
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, key])
  @@index([userId])
}

// ============= SELECTION STUDIO (Phase 7) =============
//
// SelectionSet: kullanıcının batch sonrası tasarım seçimlerini topladığı kokpit
// (Phase 8 listing input'u). Quick-start veya manuel olarak yaratılır.
//
// SelectionItem: set içindeki her tasarım için bir row. Edit semantiği
// (sourceAssetId / editedAssetId / lastUndoableAssetId) tek seviye undo'ya izin
// verir. status (pending/selected/rejected) explicit opt-in akış.

enum SelectionSetStatus {
  draft
  ready
  archived
}

enum SelectionItemStatus {
  pending
  selected
  rejected
}

model SelectionSet {
  id             String             @id @default(cuid())
  userId         String
  user           User               @relation(fields: [userId], references: [id], onDelete: Restrict)
  name           String
  status         SelectionSetStatus @default(draft)
  /// Quick-start metadata: { kind, referenceId, batchId, productTypeId, batchCreatedAt, originalCount }.
  /// Manuel create'te null olabilir.
  sourceMetadata Json?
  lastExportedAt DateTime?
  finalizedAt    DateTime?
  archivedAt     DateTime?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  items       SelectionItem[]
  mockupJobs  MockupJob[]

  @@index([userId, status])
}

model SelectionItem {
  id                  String              @id @default(cuid())
  selectionSetId      String
  selectionSet        SelectionSet        @relation(fields: [selectionSetId], references: [id], onDelete: Cascade)
  generatedDesignId   String
  generatedDesign     GeneratedDesign     @relation(fields: [generatedDesignId], references: [id], onDelete: Restrict)
  sourceAssetId       String
  sourceAsset         Asset               @relation("SelectionItemSourceAsset", fields: [sourceAssetId], references: [id], onDelete: Restrict)
  editedAssetId       String?
  editedAsset         Asset?              @relation("SelectionItemEditedAsset", fields: [editedAssetId], references: [id], onDelete: SetNull)
  lastUndoableAssetId String?
  lastUndoableAsset   Asset?              @relation("SelectionItemUndoableAsset", fields: [lastUndoableAssetId], references: [id], onDelete: SetNull)
  /// Edit op records: array of { op, params?, at }. Audit/info; replay değil.
  editHistoryJson     Json                @default("[]")
  /// Aktif heavy edit job (bg-remove). Phase 7 Task 10 paralel heavy yasağı:
  /// non-null iken applyEditAsync ikinci kez girerse ConcurrentEditError.
  /// Worker tamamlandığında (success/fail) null'a düşer.
  activeHeavyJobId    String?
  status              SelectionItemStatus @default(pending)
  position            Int
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  @@index([selectionSetId, position])
  @@index([generatedDesignId])
}

// ============= MOCKUP STUDIO (Phase 8) =============
//
// MockupTemplate: kullanıcıya görünen provider-agnostik mockup kataloğu (canvas
// vb.). Her template 1+ binding'e sahiptir; aktif binding render'da seçilir.
//
// MockupTemplateBinding: provider'a özel render konfigürasyonu (LOCAL_SHARP /
// DYNAMIC_MOCKUPS). `config` Json kolonu provider'a göre discriminated şekil
// alır (spec §3.2).
//
// MockupJob: SelectionSet → 10-görsel pack üreten aggregate. `setSnapshotId`
// deterministik set+items hash'i (spec §3.4); `coverRenderId` packPosition=0
// invariant'ı için kullanılır (cover swap atomic slot swap, spec §4.8).
//
// MockupRender: pack içindeki tek render. `packPosition` 0..9 arası; null
// olanlar arşivlenmiş swap (spec §4.4). 5-class hata sözlüğü `errorClass`
// kolonunda tutulur (spec §7.1).

enum MockupProviderId {
  LOCAL_SHARP
  DYNAMIC_MOCKUPS
}

enum MockupTemplateStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum MockupBindingStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum MockupJobStatus {
  QUEUED
  RUNNING
  COMPLETED
  PARTIAL_COMPLETE
  FAILED
  CANCELLED
}

enum MockupRenderStatus {
  PENDING
  RENDERING
  SUCCESS
  FAILED
}

enum MockupErrorClass {
  TEMPLATE_INVALID
  RENDER_TIMEOUT
  SOURCE_QUALITY
  SAFE_AREA_OVERFLOW
  PROVIDER_DOWN
}

enum PackSelectionReason {
  COVER
  TEMPLATE_DIVERSITY
  VARIANT_ROTATION
}

model MockupTemplate {
  id                String               @id @default(cuid())
  categoryId        String
  name              String
  status            MockupTemplateStatus @default(DRAFT)
  /// MinIO key — kullanıcı UI'da template kart thumbnail'i.
  thumbKey          String
  /// Desteklenen aspect ratio listesi (örn. ["2:3","3:4"]).
  aspectRatios      String[]
  /// Vibe + room + composition tag'leri (filtreleme için).
  tags              String[]
  /// En hızlı active binding'in tahmini render süresi (ms). Job ETA hesabında kullanılır.
  estimatedRenderMs Int
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  archivedAt        DateTime?

  bindings MockupTemplateBinding[]

  @@index([categoryId, status])
}

model MockupTemplateBinding {
  id                String              @id @default(cuid())
  templateId        String
  template          MockupTemplate      @relation(fields: [templateId], references: [id], onDelete: Cascade)
  providerId        MockupProviderId
  version           Int                 @default(1)
  status            MockupBindingStatus @default(DRAFT)
  /// ProviderConfig (discriminated union, spec §3.2).
  config            Json
  estimatedRenderMs Int
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  archivedAt        DateTime?

  @@unique([templateId, providerId])
  @@index([providerId, status])
}

model MockupJob {
  id             String          @id @default(cuid())
  userId         String
  user           User            @relation(fields: [userId], references: [id], onDelete: Restrict)
  setId          String
  set            SelectionSet    @relation(fields: [setId], references: [id], onDelete: Restrict)
  /// Spec §3.4 deterministik set+items hash (sha256). Re-run idempotency.
  setSnapshotId  String
  /// V1: "canvas". V2'de genişler.
  categoryId     String
  status         MockupJobStatus
  /// Hedef pack boyutu (default 10).
  packSize       Int
  /// Gerçekleşen pack boyutu (validPairs sınırı, spec §2.5).
  actualPackSize Int
  /// Cover invariant: packPosition=0 render id (cover swap = atomic slot swap, spec §4.8).
  coverRenderId  String?
  totalRenders   Int
  successRenders Int             @default(0)
  failedRenders  Int             @default(0)
  /// 5-class hata roll-up (spec §7.1).
  errorSummary   Json?
  createdAt      DateTime        @default(now())
  startedAt      DateTime?
  completedAt    DateTime?

  renders MockupRender[]

  @@index([userId, createdAt])
  @@index([setId, createdAt])
  @@index([status])
}

model MockupRender {
  id               String              @id @default(cuid())
  jobId            String
  job              MockupJob           @relation(fields: [jobId], references: [id], onDelete: Cascade)
  /// SelectionItem.id — pack üyesi tasarım.
  variantId        String
  bindingId        String
  /// RenderSnapshot (spec §3.3) — byte-stable yeniden üretim için.
  templateSnapshot Json
  /// 0..9 arası pack slot'u; null = arşivlenmiş swap (spec §4.4).
  packPosition     Int?
  selectionReason  PackSelectionReason
  status           MockupRenderStatus
  /// MinIO output asset key (success'te dolar).
  outputKey        String?
  thumbnailKey     String?
  /// 5-class hata sınıfı (spec §7.1).
  errorClass       MockupErrorClass?
  errorDetail      String?
  retryCount       Int                 @default(0)
  startedAt        DateTime?
  completedAt      DateTime?

  @@index([jobId, packPosition])
  @@index([jobId, status])
}
